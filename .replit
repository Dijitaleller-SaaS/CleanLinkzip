modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
LOG_LEVEL = "info"
PAYTR_TEST_MODE = "1"
APP_URL = "https://cleanlinktr.com"
ADMIN_EMAIL = "serkan@dijitaleller.com"
SMTP_HOST = "smtp.yandex.com"
SMTP_PORT = "465"
SMTP_FROM = "noreply@cleanlink.com"
GOOGLE_CALLBACK_URL = "https://cleanlinktr.com/api/auth/google/callback"
GOOGLE_CLIENT_ID = "24500124966-8g42fd3losnhr06bn8v6tr3tk8qll9j6.apps.googleusercontent.com"

[userenv.development]
NODE_ENV = "development"
APP_BASE_URL = "https://334e0fd1-504d-4b82-8130-4853f85e9e31-00-1s15togz0t60d.sisko.replit.dev"

[userenv.production]
NODE_ENV = "production"
APP_BASE_URL = "https://cleanlinktr.com"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/cleanlink run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=5000 NODE_ENV=production node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "BASE_PATH=/ PORT=5000 pnpm --filter @workspace/cleanlink run build && pnpm --filter @workspace/api-server run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
