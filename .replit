modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
LOG_LEVEL = "info"
PAYTR_TEST_MODE = "1"
APP_BASE_URL = "https://334e0fd1-504d-4b82-8130-4853f85e9e31-00-1s15togz0t60d.sisko.replit.dev"
APP_URL = "https://334e0fd1-504d-4b82-8130-4853f85e9e31-00-1s15togz0t60d.sisko.replit.dev"
ADMIN_EMAIL = "admin@cleanlink.com"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_FROM = "noreply@cleanlink.com"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/cleanlink run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node --enable-source-maps ./artifacts/api-server/dist/index.mjs & PORT=5000 npx vite preview --config ./artifacts/cleanlink/vite.config.ts --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/cleanlink run build && PORT=8080 pnpm --filter @workspace/api-server run build"]
